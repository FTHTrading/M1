# =============================================================================
# STABLECOIN TREASURY OS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for each environment.
# NEVER commit .env with real credentials.
# See docs/provider-integration-guide.md for credential acquisition steps.

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://treasury:treasury_pass@localhost:5432/treasury_os

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=change_me_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ─── Circle (USDC) ─────────────────────────────────────────────────────────────
# Institutional Circle Mint credentials — obtained from Circle Mint onboarding.
# See: https://developers.circle.com/circle-mint
CIRCLE_API_KEY=SANDBOX_TEST_APIKEY:your_circle_api_key_here
CIRCLE_ENTITY_ID=your_circle_entity_id_here
CIRCLE_WALLET_ID=your_circle_master_wallet_id_here
CIRCLE_WEBHOOK_SECRET=your_circle_webhook_signature_secret_here
# true = use Circle sandbox environment, false = production
CIRCLE_SANDBOX=true
CIRCLE_BASE_URL=https://api-sandbox.circle.com

# ─── Tether (USDT) ─────────────────────────────────────────────────────────────
# Tether institutional acquisition is a verified OTC/treasury process.
# See: https://tether.to/en/institutional  and docs/provider-integration-guide.md
# Modes: sandbox | otc_desk | tether_direct
TETHER_ACCOUNT_MODE=sandbox
TETHER_REFERENCE_DETAILS=your_tether_account_reference_or_otc_desk_details
ENABLE_USDT=true

# ─── Banking Rails ────────────────────────────────────────────────────────────
# Modes: webhook | manual | csv_import
BANK_RAIL_MODE=manual
BANK_WEBHOOK_SECRET=your_bank_webhook_hmac_secret
ENABLE_MANUAL_BANK_IMPORT=true

# ─── Object Storage (MinIO / S3-compatible) ───────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=treasury-documents
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=treasury-os-api
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# ─── Feature Flags ────────────────────────────────────────────────────────────
# FEATURE_SANDBOX_ONLY=true forces all provider calls through sandbox adapters
# regardless of individual provider settings.
FEATURE_SANDBOX_ONLY=true
FEATURE_LIVE_TRANSFERS=false

# ─── Network & Settlement ─────────────────────────────────────────────────────
# Networks: ethereum | solana | polygon | base | tron
DEFAULT_SETTLEMENT_NETWORK=ethereum
ENABLE_TRON=false

# ─── Policy Limits ────────────────────────────────────────────────────────────
# Amount in USD cents (e.g. 100000000 = $1,000,000 USD)
REQUIRED_APPROVAL_THRESHOLD_USD=50000
MAX_SINGLE_TX_USD=10000000

# ─── Blockchain RPC endpoints (optional — for on-chain balance reads) ───────────
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_infura_project_id
POLYGON_RPC_URL=https://polygon-rpc.com
BASE_RPC_URL=https://mainnet.base.org
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
TRON_API_URL=https://api.trongrid.io

# ─── Email (optional — notifications/alerts) ─────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=treasury-alerts@yourdomain.com
ALERT_EMAIL_TO=ops@yourdomain.com

# ─── FTH L1 Runtime — Transaction Verification Engine (TEV) ──────────────────
# Endpoint for the FTH L1 Rust runtime (default: Finn localhost port 7700)
FTH_L1_ENDPOINT=http://localhost:7700
FTH_L1_API_KEY=your_fth_l1_api_key_here
# Set to true to BLOCK transactions when FTH L1 is unreachable (hard dependency)
FTH_L1_HARD_BLOCK=false
FTH_L1_TIMEOUT_MS=3000

# ─── Apostle Chain — On-Chain Settlement Finality (Chain 7332) ────────────────
APOSTLE_ENDPOINT=http://localhost:7332
# Agent UUID registered on Apostle Chain for this treasury instance
APOSTLE_AGENT_ID=your_agent_uuid_here
# Ed25519 private key (64 hex chars) — leave blank to use zero-sig (non-settling)
APOSTLE_AGENT_PRIVATE_KEY=
# Agent ID that receives USDF settlement credits on Apostle Chain
APOSTLE_TREASURY_AGENT_ID=your_treasury_apostle_agent_uuid_here
APOSTLE_TIMEOUT_MS=5000

# ─── Sanctions Screening Vendors ─────────────────────────────────────────────
# SANCTIONS_VENDOR: comply_advantage | mock (default: comply_advantage)
SANCTIONS_VENDOR=comply_advantage
COMPLY_ADVANTAGE_API_KEY=your_comply_advantage_api_key_here
COMPLY_ADVANTAGE_BASE_URL=https://api.complyadvantage.com

# ON_CHAIN_SCREENING_VENDOR: trm | chainalysis | mock (default: trm)
ON_CHAIN_SCREENING_VENDOR=trm
TRM_API_KEY=your_trm_api_key_here
TRM_BASE_URL=https://api.trmlabs.com/public/v2
CHAINALYSIS_API_KEY=your_chainalysis_api_key_here
CHAINALYSIS_BASE_URL=https://api.chainalysis.com/api/kyt/v2

# ─── Finn AI Compliance Bridge ────────────────────────────────────────────────
# Set FINN_COMPLIANCE_ENABLED=true to route high-risk transactions through Finn
# for a secondary AI compliance review before approval.
# Requires Finn runtime to be running at FINN_COMPLIANCE_ENDPOINT.
FINN_COMPLIANCE_ENABLED=false
FINN_COMPLIANCE_ENDPOINT=http://localhost:7700/v1/compliance/review
FINN_COMPLIANCE_API_KEY=
