{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "APP_URL",
    "AUTH_SECRET",
    "CIRCLE_API_KEY",
    "CIRCLE_ENTITY_ID",
    "CIRCLE_WEBHOOK_SECRET",
    "CIRCLE_SANDBOX",
    "TETHER_ACCOUNT_MODE",
    "TETHER_REFERENCE_DETAILS",
    "BANK_RAIL_MODE",
    "BANK_WEBHOOK_SECRET",
    "S3_ENDPOINT",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_BUCKET",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "OTEL_SERVICE_NAME",
    "FEATURE_LIVE_TRANSFERS",
    "FEATURE_SANDBOX_ONLY",
    "DEFAULT_SETTLEMENT_NETWORK",
    "REQUIRED_APPROVAL_THRESHOLD_USD",
    "MAX_SINGLE_TX_USD",
    "ENABLE_USDT",
    "ENABLE_TRON",
    "ENABLE_MANUAL_BANK_IMPORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
